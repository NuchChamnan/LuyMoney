rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasActiveSubscription() {
      let subPath = /databases/$(database)/documents/subscriptions/$(request.auth.uid);
      return exists(subPath) &&
             get(subPath).data.isActive == true &&
             get(subPath).data.expiryDate > request.time;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin() ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    // ── Subscriptions ──────────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Categories ─────────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Banners ────────────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Content (Videos) ──────────────────────────────────────────────────────
    match /videos/{videoId} {
      allow read: if isAuthenticated() && (hasActiveSubscription() || isAdmin());
      allow write: if isAdmin();

      // ── Comments ──────────────────────────────────────────────────────────
      // Read is intentionally just isAuthenticated(): this collection is read
      // via a realtime snapshots() listener, and rules with get()/exists()
      // calls are re-evaluated on every update, which slows down live updates
      // and multiplies document reads. Write paths keep the stricter checks
      // since they only run once per action.
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (hasActiveSubscription() || isAdmin()) &&
          request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuthenticated() &&
          (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // ── Content (Articles) ────────────────────────────────────────────────────
    match /articles/{articleId} {
      allow read: if isAuthenticated() && (hasActiveSubscription() || isAdmin());
      allow write: if isAdmin();

      // ── Comments (same rationale as videos/comments above) ──────────────────
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (hasActiveSubscription() || isAdmin()) &&
          request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuthenticated() &&
          (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // ── Chats ─────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isOwner(chatId) || isAdmin();
      allow create, update: if isOwner(chatId) || isAdmin();

      match /messages/{messageId} {
        allow read: if isOwner(chatId) || isAdmin();
        allow create: if isAdmin() ||
          (isOwner(chatId) && request.resource.data.senderId == request.auth.uid);
        allow update, delete: if isAdmin();
      }
    }

    // ── Admin-only collections ─────────────────────────────────────────────────
    match /admin_notifications/{docId} {
      // Broadcast messages: any signed-in user can read so the in-app
      // Notifications tab can show them; only admins can create/send.
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /promo_codes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // immutable logs
    }

    // ── Referrals ─────────────────────────────────────────────────────────────
    match /referrals/{refId} {
      allow read: if isAuthenticated() && (
        resource.data.referrerId == request.auth.uid ||
        resource.data.refereeId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.referrerId == request.auth.uid ||
        resource.data.refereeId == request.auth.uid ||
        isAdmin()
      );
    }
  }
}
